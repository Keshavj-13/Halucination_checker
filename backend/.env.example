# LLM Configuration (weak voter only)
BACKEND_PORT_START=8000
BACKEND_PORT_FALLBACK_START=8001

LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_key
LLM_MODEL=gemini-2.5-flash

# Embedding configuration (semantic voter)
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_URL=${OLLAMA_BASE_URL}/api/embeddings
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_TIMEOUT_SECONDS=8
EMBEDDING_BATCH_SIZE=16
EMBEDDING_MAX_IN_FLIGHT=24
EMBEDDING_USE_BATCH_ENDPOINT=false
OLLAMA_NUM_GPU=1
OLLAMA_NUM_THREAD=8
TRACE_ENABLED=true
TRACE_CONSOLE_EVENTS=false
TRACE_TQDM_ENABLED=true
PIPELINE_SERIAL_MODE=false
PIPELINE_PROCESS_MODE=true
CLAIM_PROCESS_WORKERS=5
VOTERS_SERIAL_MODE=true
CONSENSUS_USE_CALIBRATOR=false

# Retrieval and performance
MAX_SEARCH_RESULTS=5
MAX_EVIDENCE_CHUNKS=10
HTTP_TIMEOUT_SECONDS=8
SCRAPE_CONCURRENCY=3
RETRIEVAL_DEADLINE_SECONDS=4.5
MAX_PAGES_TO_PROCESS=3
CLAIM_PIPELINE_DEADLINE_SECONDS=14.0
VOTING_TIMEOUT_SECONDS=12.0
RETRIEVAL_STAGE_TIMEOUT_SECONDS=14.0
VOTER_TIMEOUT_SECONDS=7.0
CPU_WORKERS=1
VOTER_CPU_WORKERS=1
MAX_CLAIMS_IN_FLIGHT=5
CLAIM_ATOMIC_SPLIT_ENABLED=false

# GPU note:
# Semantic embeddings run through EMBEDDING_URL provider (e.g., Ollama),
# which can use GPU automatically when available.

# Optional extraction mode
USE_LLM_EXTRACTION=false
